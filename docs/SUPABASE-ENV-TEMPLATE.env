# Copy this file to the repo root as .env.supabase.new
# (The real .env.supabase.new is gitignored — use Terminal or Cmd+Shift+P → "Open File")
#
#   cp docs/SUPABASE-ENV-TEMPLATE.env .env.supabase.new
#
# Then replace YOUR_DB_PASSWORD with your Supabase database password.

SUPABASE_PROJECT_ID=treezkwkkdkvdqaozqhu
SUPABASE_URL=https://treezkwkkdkvdqaozqhu.supabase.co
SUPABASE_ANON_KEY=sb_publishable_CuL_NygVOqrD0i0slJvwmQ_G2IwJoQG
SUPABASE_SERVICE_ROLE_KEY=

# Direct (5432) — Prisma push / migrations
DIRECT_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.treezkwkkdkvdqaozqhu.supabase.co:5432/postgres

# Runtime — use Transaction pooler (6543) from Dashboard when ready
# For bootstrap, direct URL on both lines is OK:
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.treezkwkkdkvdqaozqhu.supabase.co:5432/postgres
