# ═══════════════════════════════════════════════════════════
# Growvisi — Vercel API (growvisi-api)
# Import this in Vercel → Settings → Environment Variables
# Or paste each row in the "New Project" env section
# ═══════════════════════════════════════════════════════════

# ─── Required (database) ─────────────────────────────────
DATABASE_URL=postgresql://postgres.qzeiggsgnruvxbvdesfd:YOUR_DB_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.qzeiggsgnruvxbvdesfd:YOUR_DB_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# ─── Required (Redis — MUST be Upstash, not localhost) ───
# Create free DB: https://console.upstash.com → copy Redis URL
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# ─── Required (auth) ───────────────────────────────────────
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=production

# ─── Required (CORS + links) ─────────────────────────────
# Update NEXT_PUBLIC_APP_URL after you deploy the web app on Vercel
NEXT_PUBLIC_APP_URL=https://www.growvisi.in
CORS_ORIGINS=https://growvisi.in,https://www.growvisi.in

# ─── Required (WhatsApp webhooks) ──────────────────────────
# No trailing newline — paste exactly one line (Windows CLI can add \r\n)
WEBHOOK_PUBLIC_URL=https://api.growvisi.in
WHATSAPP_VERIFY_TOKEN=growvisi-webhook-verify
WHATSAPP_API_VERSION=v21.0

# ─── Meta WhatsApp (add when Meta app is configured) ───────
META_APP_ID=1694805491426991
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
# Set to true after Meta App Review + Tech Provider approval
WHATSAPP_EMBEDDED_SIGNUP_LIVE=true
WHATSAPP_APP_SECRET=

# ─── Password reset emails (optional but recommended) ──────
RESEND_API_KEY=
EMAIL_FROM=Growvisi <it@growvisi.com>
# Vercel Cron auth — required for token reminder emails (schedule in vercel.json)
# Generate: openssl rand -base64 32
CRON_SECRET=

# Dedicated key for WhatsApp token encryption at rest (openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=

# Cookie sharing www.growvisi.in ↔ api.growvisi.in
COOKIE_DOMAIN=.growvisi.in

# Sentry (recommended) — same DSN on API; use NEXT_PUBLIC_SENTRY_DSN on web
SENTRY_DSN=

# Latency probe — keep false unless debugging (requires conversationId query param)
LATENCY_PROBE_ENABLED=false

# ─── AI (recommended — classification/drafts disabled without key) ───
OPENAI_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini
AI_CLASSIFY_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Razorpay (paid upgrades) ───────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_GROWTH=
RAZORPAY_PLAN_PRO=

# ─── Do NOT add on API (web-only) ──────────────────────────
# NEXT_PUBLIC_API_URL
# NEXT_PUBLIC_WS_URL
# NEXT_PUBLIC_META_APP_ID
# NEXT_PUBLIC_SENTRY_DSN
# SEED_* (never on production)
