# ═══════════════════════════════════════════════════════════
# Growvisi (growvisi.com) — Supabase + Upstash (recommended, no Docker)
# ═══════════════════════════════════════════════════════════

# ─── Supabase Postgres ───────────────────────────────────
# Pooled URL (port 6543) — use for API runtime (DATABASE_URL)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct URL (port 5432) — use for Prisma db push / migrate (DIRECT_URL)
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase project (Dashboard → Settings → API)
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Redis (Upstash free tier — required for WhatsApp queues) ─
# https://console.upstash.com → Create database → Node.js URL
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379

# ─── API ──────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development
JWT_SECRET=change-me-use-openssl-rand-base64-32-minimum-length
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Web (local dev) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Production (set on Vercel — reference only) ───────────
# NEXT_PUBLIC_APP_URL=https://growvisi.com
# NEXT_PUBLIC_API_URL=https://api.growvisi.com/api/v1
# NEXT_PUBLIC_WS_URL=wss://api.growvisi.com
# CORS_ORIGINS=https://growvisi.com,https://www.growvisi.com
# WEBHOOK_PUBLIC_URL=https://api.growvisi.com

# Password reset emails (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Growvisi <noreply@growvisi.com>

CORS_ORIGINS=

# ─── Seed (optional — pnpm db:seed) ───────────────────────
SEED_USER_EMAIL=demo@growvisi.com
SEED_USER_PASSWORD=demo123456
SEED_ORG_NAME=Demo Company

# ─── WhatsApp Cloud API ───────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WEBHOOK_PUBLIC_URL=

# Meta Embedded Signup (customer self-serve connect)
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
# Set to true after Meta App Review + Tech Provider — enables "Continue with Facebook"
WHATSAPP_EMBEDDED_SIGNUP_LIVE=false
# Optional: 6-digit PIN for new Cloud API number registration
META_WABA_REGISTER_PIN=

# Public (safe to expose in web — also set for client SDK)
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=

# ─── AI ───────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openai
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_CHAT_MODEL=gpt-4o

# ─── Observability (optional) ─────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
OTEL_EXPORTER_OTLP_ENDPOINT=

# ═══════════════════════════════════════════════════════════
# Docker alternative (local Postgres + Redis)
# ═══════════════════════════════════════════════════════════
# DATABASE_URL=postgresql://growvisi:growvisi_dev@localhost:5432/growvisi?schema=public
# DIRECT_URL=postgresql://growvisi:growvisi_dev@localhost:5432/growvisi?schema=public
# REDIS_URL=redis://localhost:6379
