# ═══════════════════════════════════════════════════════════════════
# STEP 1: Copy this file to .env.supabase.new (one time)
#   cp .env.supabase.new.example .env.supabase.new
#
# STEP 2: Open .env.supabase.new and replace YOUR_DB_PASSWORD below
#   That password is the one YOU typed when creating the Supabase project
#   (Supabase Dashboard → Project → Database password). It is NOT in this repo.
#
# STEP 3: Run from repo root:
#   pnpm db:merge-supabase-env
#   pnpm db:setup-fresh -- --seed
# ═══════════════════════════════════════════════════════════════════

SUPABASE_PROJECT_ID=treezkwkkdkvdqaozqhu
SUPABASE_URL=https://treezkwkkdkvdqaozqhu.supabase.co
SUPABASE_ANON_KEY=sb_publishable_CuL_NygVOqrD0i0slJvwmQ_G2IwJoQG
SUPABASE_SERVICE_ROLE_KEY=

# Replace YOUR_DB_PASSWORD in DIRECT_URL (same password both places)
# Region from Dashboard → Project Settings → General (e.g. ap-south-1 for Mumbai)
SUPABASE_DB_REGION=ap-south-1
# Optional: paste full pooler host from Dashboard if aws-0-{region} fails
# SUPABASE_POOLER_HOST=aws-0-ap-south-1.pooler.supabase.com

DIRECT_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.treezkwkkdkvdqaozqhu.supabase.co:5432/postgres

# Runtime on Vercel uses transaction pooler (6543) — set-vercel-supabase-env derives this from DIRECT_URL
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.treezkwkkdkvdqaozqhu.supabase.co:5432/postgres
