# Shared ignores for Vercel Git/CLI deploys (monorepo root)
# Do NOT list apps/web or apps/api here — each Vercel project needs the full workspace.
node_modules
**/node_modules/**
**/.git/**
.turbo
**/.turbo/**
**/.next/cache/**
*.log
.env*
**/.env.check
**/.env.verify*
**/.env.api.check
.vercel.web.bak
