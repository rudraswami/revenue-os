{
  "name": "revenue-os",
  "version": "0.1.0",
  "private": true,
  "description": "AI Revenue Operating System for WhatsApp-first businesses",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@revenue-os/api",
    "dev:web": "turbo run dev --filter=@revenue-os/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @revenue-os/database generate",
    "db:migrate": "pnpm --filter @revenue-os/database migrate:dev",
    "db:push": "pnpm --filter @revenue-os/database push",
    "db:studio": "pnpm --filter @revenue-os/database studio",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "prepare": "husky || true",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
