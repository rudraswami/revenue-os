{
  "name": "growvisi",
  "version": "0.1.0",
  "private": true,
  "description": "Growvisi — WhatsApp growth platform (growvisi.com)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@growvisi/api",
    "dev:web": "turbo run dev --filter=@growvisi/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @growvisi/database generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @growvisi/database migrate:dev",
    "db:push": "dotenv -e .env -- pnpm --filter @growvisi/database push",
    "db:auth-migrate": "dotenv -e .env -- node scripts/migrate-auth-production.js",
    "db:email-verification-migrate": "dotenv -e .env -- node scripts/migrate-email-verification.js",
    "db:razorpay-migrate": "dotenv -e .env -- node scripts/migrate-razorpay-invites.js",
    "db:verify": "dotenv -e .env -- node scripts/verify-db-migration.js",
    "db:deploy": "dotenv -e .env -- pnpm --filter @growvisi/database migrate:deploy",
    "db:seed": "dotenv -e .env -- pnpm --filter @growvisi/database seed",
    "db:studio": "dotenv -e .env -- pnpm --filter @growvisi/database studio",
    "supabase": "supabase",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push",
    "supabase:pull": "supabase db pull",
    "supabase:status": "supabase status",
    "supabase:types": "supabase gen types typescript --linked -o packages/shared/src/supabase.types.ts",
    "setup:supabase": "powershell -ExecutionPolicy Bypass -File scripts/supabase/setup.ps1",
    "setup:all": "pnpm setup:supabase && pnpm db:push && pnpm db:seed",
    "setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "vercel:env:domain": "node scripts/set-vercel-growvisi-in-env.js",
    "vercel:env:razorpay": "node scripts/set-vercel-razorpay-env.js",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "prepare": "husky || true",
    "postinstall": "node -e \"if(process.env.VERCEL==='1'||process.env.CI==='true')process.exit(0);require('child_process').execFileSync('node',['scripts/postinstall-prisma.js'],{stdio:'inherit'})\""
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "pg": "^8.21.0",
    "prettier": "^3.4.2",
    "supabase": "^2.2.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
