{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nestjs",
  "regions": ["bom1"],
  "installCommand": "cd ../.. && corepack enable && NODE_ENV=development pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@growvisi/api",
  "crons": [
    {
      "path": "/api/v1/internal/cron/reconcile-inbound",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/v1/internal/cron/whatsapp-token-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/v1/internal/cron/whatsapp-token-refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/v1/internal/cron/followup-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/v1/internal/cron/daily-digest",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/internal/cron/scheduled-campaigns",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/v1/internal/cron/data-retention",
      "schedule": "0 4 * * 0"
    }
  ]
}
