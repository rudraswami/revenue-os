{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nestjs",
  "installCommand": "cd ../.. && corepack enable && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@growvisi/api",
  "crons": [
    {
      "path": "/api/v1/internal/cron/whatsapp-token-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
